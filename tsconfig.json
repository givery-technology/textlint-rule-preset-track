{
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node10",
    "target": "ES2022",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "rootDir": "src",
    "outDir": "lib"
  },
  "include": ["src/**/*.ts"]
}
