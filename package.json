{
  "name": "textlint-rule-preset-track",
  "version": "2.0.0",
  "description": "textlint rule for Track",
  "main": "lib/textlint-rule-preset-track.js",
  "scripts": {
    "docs": "node script/generate_readme.js",
    "test": "mocha test/",
    "test:example": "(cd example && npm install && npm test)",
    "test:docs": "mocha script/test/generate_readme.spec.js",
    "test:all": "npm run test && npm run test:example && npm run test:docs",
    "build": "tsc && cp src/prh.yml lib/prh.yml",
    "prepare": "npm run build",
    "pretest": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/givery-technology/textlint-rule-preset-track.git"
  },
  "homepage": "https://github.com/givery-technology/textlint-rule-preset-track",
  "bugs": {
    "url": "https://github.com/givery-technology/textlint-rule-preset-track/issues"
  },
  "author": "mitsuruog",
  "license": "MIT",
  "files": [
    "lib/",
    "src/"
  ],
  "keywords": [
    "textlint",
    "preset"
  ],
  "dependencies": {
    "@textlint-ja/textlint-rule-no-insert-dropping-sa": "^2.0.1",
    "@textlint-rule/textlint-rule-no-invalid-control-character": "^3.0.0",
    "@textlint-rule/textlint-rule-no-unmatched-pair": "^2.0.4",
    "@textlint/module-interop": "^15.7.1",
    "textlint-rule-common-misspellings": "^1.0.1",
    "textlint-rule-date-weekday-mismatch": "^1.1.1",
    "textlint-rule-ja-no-abusage": "^3.0.0",
    "textlint-rule-ja-no-mixed-period": "^3.0.2",
    "textlint-rule-ja-no-successive-word": "^2.0.1",
    "textlint-rule-ja-no-weak-phrase": "^2.0.0",
    "textlint-rule-ja-unnatural-alphabet": "^2.0.1",
    "textlint-rule-max-comma": "^4.0.0",
    "textlint-rule-max-kanji-continuous-len": "^1.1.1",
    "textlint-rule-max-ten": "^5.0.0",
    "textlint-rule-no-double-negative-ja": "^2.0.1",
    "textlint-rule-no-doubled-conjunction": "^3.0.1",
    "textlint-rule-no-doubled-conjunctive-particle-ga": "^3.0.0",
    "textlint-rule-no-doubled-joshi": "^5.1.1",
    "textlint-rule-no-dropping-the-ra": "^3.0.0",
    "textlint-rule-no-exclamation-question-mark": "^1.1.0",
    "textlint-rule-no-hankaku-kana": "^2.0.1",
    "textlint-rule-no-mix-dearu-desumasu": "^6.0.4",
    "textlint-rule-no-mixed-zenkaku-and-hankaku-alphabet": "^1.0.1",
    "textlint-rule-no-nfd": "^2.0.2",
    "textlint-rule-no-todo": "^2.0.1",
    "textlint-rule-prefer-tari-tari": "^1.0.3",
    "textlint-rule-preset-ai-writing": "^1.1.0",
    "textlint-rule-preset-jtf-style": "^3.0.3",
    "textlint-rule-prh": "^6.1.0",
    "textlint-rule-sentence-length": "^5.2.1",
    "textlint-rule-spellcheck-tech-word": "^5.0.0"
  },
  "devDependencies": {
    "@textlint/ast-node-types": "^15.7.1",
    "@textlint/kernel": "^15.7.1",
    "@textlint/textlint-plugin-markdown": "^15.7.1",
    "@textlint/types": "^15.7.1",
    "@types/node": "^22.0.0",
    "markdown-toc": "^1.2.0",
    "mocha": "^11.7.5",
    "textlint": "^15.7.1",
    "typescript": "^5.9.0"
